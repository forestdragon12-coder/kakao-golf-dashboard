rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 승인된 사용자 목록
    match /approved_users/{emailHash} {
      allow read: if request.auth != null;
      // admin은 모든 쓰기 가능
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/approved_users/$(request.auth.token.email)).data.role == 'admin';
      // 본인 문서의 login_count, last_login_at만 업데이트 허용
      allow update: if request.auth != null
        && emailHash == request.auth.token.email
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['login_count', 'last_login_at']);
    }

    // 대기 요청 — 인증된 사용자 누구나 자기 요청 생성, admin만 전체 읽기/수정
    match /pending_requests/{emailHash} {
      allow create: if request.auth != null;
      allow read: if request.auth != null
        && (
          emailHash == request.auth.token.email
          || get(/databases/$(database)/documents/approved_users/$(request.auth.token.email)).data.role == 'admin'
        );
      allow update, delete: if request.auth != null
        && get(/databases/$(database)/documents/approved_users/$(request.auth.token.email)).data.role == 'admin';
    }

    // 대시보드 데이터 — 승인된 사용자만 읽기
    match /dashboard_data/{docId} {
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/approved_users/$(request.auth.token.email))
        && get(/databases/$(database)/documents/approved_users/$(request.auth.token.email)).data.active == true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/approved_users/$(request.auth.token.email)).data.role == 'admin';
    }

    // 접속 로그 — 인증된 사용자 쓰기, admin만 읽기
    match /access_logs/{logId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/approved_users/$(request.auth.token.email)).data.role == 'admin';
    }

    // 설정 — admin만 읽기/쓰기
    match /settings/{docId} {
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/approved_users/$(request.auth.token.email));
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/approved_users/$(request.auth.token.email)).data.role == 'admin';
    }

    // AI 사용량 — 본인 데이터만 읽기/쓰기
    match /ai_usage/{docId} {
      allow create, update: if request.auth != null
        && docId.matches(request.auth.token.email + '_.*');
      allow read: if request.auth != null
        && (
          docId.matches(request.auth.token.email + '_.*')
          || get(/databases/$(database)/documents/approved_users/$(request.auth.token.email)).data.role == 'admin'
        );
    }

    // 채팅 내역 — 본인 데이터만 읽기/쓰기, admin은 전체
    match /chat_histories/{docId} {
      allow create: if request.auth != null
        && request.resource.data.email == request.auth.token.email;
      allow read, update, delete: if request.auth != null
        && (
          resource.data.email == request.auth.token.email
          || get(/databases/$(database)/documents/approved_users/$(request.auth.token.email)).data.role == 'admin'
        );
    }

    // 기본: 모두 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
